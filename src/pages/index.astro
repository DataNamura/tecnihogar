---
import "@fontsource-variable/inter";
import Header from "~/components/header.astro";
import Splash from "~/components/splash.astro";
import AboutUs from "~/components/about-us.astro";
import Services from "~/components/services.astro";
import Guarantee from "~/components/guarantee.astro";
import Features from "~/components/features.astro";
import Brands from "~/components/brands.astro";
import Testimonials from "~/components/testimonials.astro";
import FAQ from "~/components/faq.astro";
import FindUs from "~/components/findus.astro";
import Footer from "~/components/footer.astro";
import WhatsAppButton from "~/components/whatsapp-button.astro";  // Importa el botón de WhatsApp
import "~/styles/index.css";

const { generator, site } = Astro;
const image = new URL("social.jpg", site);
const description =
  "Servicio profesional de reparación de electrodomésticos en Tenerife Sur. Especialistas en reparación de lavadoras, neveras, lavavajillas y más. Ubicados en San Isidro, dando servicio a toda la zona sur de Tenerife.";
---

<!doctype html>
<html lang="es" class="h-full motion-safe:scroll-smooth" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="generator" content={generator} />

    <title>Reparación Electrodomésticos Tenerife Sur | TecniHogar | San Isidro</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="reparación electrodomésticos Tenerife Sur, servicio técnico San Isidro, reparación lavadoras, técnico electrodomésticos, reparación neveras Tenerife Sur, electrodomésticos San Isidro, reparación lavavajillas" />

    <!-- Metadatos adicionales para SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="author" content="TecniHogar Tenerife" />
    <meta name="geo.region" content="ES-CN" />
    <meta name="geo.placename" content="San Isidro, Tenerife Sur" />
    <link rel="canonical" href={site} />

    <!-- social media -->
    <meta property="og:title" content="Reparación Electrodomésticos Tenerife Sur | TecniHogar | San Isidro" />
    <meta property="og:type" content="website" />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={site} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="TecniHogar Tenerife Sur" />
    <meta name="twitter:card" content="summary_large_image" />
    
    <!-- Schema.org markup para negocio local -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "TecniHogar Tenerife Sur",
        "image": "",
        "@id": "",
        "url": "",
        "telephone": "+34603403094",
        "priceRange": "€€",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "C. la Vera, 10, Local 1 Bajo",
          "addressLocality": "San Isidro",
          "addressRegion": "Santa Cruz de Tenerife",
          "postalCode": "38611",
          "addressCountry": "ES"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": "28.0891",
          "longitude": "-16.6337"
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday",
              "Saturday",
              "Sunday"
            ],
            "opens": "09:00",
            "closes": "17:00"
          }
        ],
        "sameAs": [
          ""
        ]
      }
    </script>
  </head>
  <body
    class="h-full overflow-x-hidden bg-default text-default text-base selection:bg-secondary selection:text-white"
  >
    <Header />
    <Splash />
    <AboutUs />
    <Services />
    <Guarantee />
    <Features />
    <Brands />
    <Testimonials />
    <FAQ />
    <FindUs /> <!-- Sección Find Us -->
    <Footer />
    <WhatsAppButton /> <!-- Botón de WhatsApp -->
  </body>
</html>

<style>
  :root {
    --accent: 136, 58, 234;
    --accent-light: 224, 204, 250;
    --accent-dark: 49, 10, 101;
    --accent-gradient: linear-gradient(
      45deg,
      rgb(var(--accent)),
      rgb(var(--accent-light)) 30%,
      white 60%
    );
  }
  html {
    font-family: system-ui, sans-serif;
    background: #13151a;
    background-size: 224px;
  }
  code {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      Liberation Mono,
      DejaVu Sans Mono,
      Bitstream Vera Sans Mono,
      Courier New,
      monospace;
  }
</style>
