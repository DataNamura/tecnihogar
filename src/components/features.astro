---
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
import type { FeatureItem } from "~/types";

const features: Array<FeatureItem> = [
  {
    title: "Desplazamiento Gratuito",
    description:
      "El desplazamiento es totalmente gratuito si se realiza la reparación. Sin costes adicionales en toda la isla.",
    icon: "mdi:car",
  },
  {
    title: "Reparación Rápida en Tenerife",
    description:
      "Respuesta inmediata en toda la isla. Solucionamos tus averías en el mismo día.",
    icon: "mdi:clock-fast",
  },
  {
    title: "Técnicos Certificados",
    description:
      "Equipo profesional certificado con experiencia en todas las marcas de electrodomésticos y servicio técnico oficial.",
    icon: "mdi:certificate",
  },
  {
    title: "Garantía Local",
    description:
      "Servicio con garantía por escrito en toda la isla. Respaldo total en nuestras reparaciones.",
    icon: "mdi:shield-check",
  },
  {
    title: "Presupuesto Sin Compromiso",
    description:
      "Precios competitivos sin sorpresas. Presupuesto detallado antes de cada reparación.",
    icon: "mdi:cash",
  },
  {
    title: "Repuestos Originales Garantizados",
    description:
      "Stock permanente de repuestos originales para reparaciones duraderas de electrodomésticos.",
    icon: "mdi:tools",
  },
];

---

<ContentSection title="¿Por qué elegir nuestro Servicio Técnico?" id="features">
  <Fragment slot="lead">
    Los <span class="text-primary">expertos en reparación</span> de electrodomésticos en <span class="text-primary">Tenerife</span>. 
    Servicio en <span class="text-primary">San Isidro</span>, <span class="text-primary">Santa Cruz</span> y <span class="text-primary">La Laguna</span>. 
    Más de <span class="text-primary">15 años</span> solucionando averías.
  </Fragment>
  <ul class="grid max-w-6xl grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
    {
      features.map(({ title, description, icon }) => (
        <li class="flex flex-col items-center gap-4 border border-default bg-offset p-6">
          <div class="size-16 rounded-full border-2 border-current p-3">
            <Icon name={icon} class="size-full" />
          </div>
          <p class="text-center font-extrabold text-xl text-primary">{title}</p>
          <p class="text-center text-offset text-sm">{description}</p>
        </li>
      ))
    }
  </ul>
</ContentSection>