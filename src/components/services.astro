      "category": "Reparación Electrodomésticos"
    }
  },
  {
    title: "Secadoras",
    icon: "mdi:tumble-dryer",
    image: "https://images.unsplash.com/photo-1604335399105-a0c585fd81a1?q=80&w=800&auto=format&fit=crop",
    problems: [
      "No calienta o seca mal",
      "Tambor no gira",
      "Ruidos anormales",
      "Ciclo incompleto",
      "Problemas eléctricos"
    ],
    description: "Reparación profesional de secadoras en Tenerife Sur. Servicio técnico multimarca con experiencia en Bosch, Siemens, Balay y más. Solución rápida y garantizada.",
    schema: {
      "@type": "Service",
      "name": "Reparación de Secadoras en Tenerife Sur",
      "areaServed": "Tenerife Sur",
      "category": "Reparación Electrodomésticos"
    }
  },
  {
    title: "Lavavajillas",
    icon: "mdi:dishwasher",
    image: "https://images.unsplash.com/photo-1581622558663-b2e33377dfb2?q=80&w=800&auto=format&fit=crop",
    problems: [
      "No desagua correctamente",
      "Mala limpieza",
      "Fugas de agua",
      "No enciende",
