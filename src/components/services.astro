---
import ContentSection from "~/components/content-section.astro";
import { Icon } from "astro-icon/components";

const services = [
  {
    title: "Lavadoras",
    icon: "mdi:washing-machine",
    image: "https://images.unsplash.com/photo-1626806787461-102c1bfaaea1?q=80&w=800&auto=format&fit=crop",
    problems: [
      "No centrifuga o centrifuga mal",
      "No desagua o pierde agua",
      "Ruidos extraños al centrifugar",
      "No calienta el agua",
      "Error en el programa"
    ],
    description: " Servicio técnico oficial de lavadoras en Tenerife Sur. Reparamos todas las marcas: Balay, Bosch, Samsung, LG, Siemens. Diagnóstico en 24h, solución garantizada y piezas originales.",
    schema: {
      "@type": "Service",
      "name": "Reparación de Lavadoras en Tenerife Sur",
      "areaServed": "Tenerife Sur",
      "category": "Reparación Electrodomésticos"
    }
  },
  {
    title: "Refrigeradores",
    icon: "mdi:fridge",
    image: "https://images.unsplash.com/photo-1536353284924-9220c464e262?q=80&w=800&auto=format&fit=crop",
    problems: [
      "No enfría o enfría poco",
      "Ruido excesivo",
      "Formación excesiva de hielo",
      "Alto consumo eléctrico",
      "Pérdidas de agua"
    ],
    description: " Expertos en reparación de neveras y refrigeradores en Tenerife Sur. Servicio urgente 24/48h para averías de temperatura. Trabajamos con todas las marcas principales.",
    schema: {
      "@type": "Service",
      "name": "Reparación de Refrigeradores en Tenerife Sur",
      "areaServed": "Tenerife Sur",
      "category": "Reparación Electrodomésticos"
    }
  },
  {
    title: "Secadoras",
    icon: "mdi:tumble-dryer",
    image: "https://images.unsplash.com/photo-1604335399105-a0c585fd81a1?q=80&w=800&auto=format&fit=crop",
    problems: [
      "No calienta o seca mal",
      "Tambor no gira",
      "Ruidos anormales",
      "Ciclo incompleto",
      "Problemas eléctricos"
    ],
    description: " Reparación profesional de secadoras en Tenerife Sur. Servicio técnico multimarca con experiencia en Bosch, Siemens, Balay y más. Solución rápida y garantizada.",
    schema: {
      "@type": "Service",
      "name": "Reparación de Secadoras en Tenerife Sur",
      "areaServed": "Tenerife Sur",
      "category": "Reparación Electrodomésticos"
    }
  },
  {
    title: "Lavavajillas",
    icon: "mdi:dishwasher",
    image: "https://images.unsplash.com/photo-1581622558663-b2e33377dfb2?q=80&w=800&auto=format&fit=crop",
    problems: [
      "No desagua correctamente",
      "Mala limpieza",
      "Fugas de agua",
      "No enciende",
      "Ruidos extraños"
    ],
    description: " Servicio técnico especializado en lavavajillas en Tenerife Sur. Reparación de todas las marcas con garantía. Diagnóstico mismo día y presupuesto sin compromiso.",
    schema: {
      "@type": "Service",
      "name": "Reparación de Lavavajillas en Tenerife Sur",
      "areaServed": "Tenerife Sur",
      "category": "Reparación Electrodomésticos"
    }
  },
  {
    title: "Hornos",
    icon: "mdi:stove",
    image: "/horno.jpg",
    problems: [
      "No calienta o calienta mal",
      "Temperatura irregular",
      "Problemas de puerta",
      "Fallo en grill/resistencias",
      "Panel de control"
    ],
    description: " Especialistas en reparación de hornos en Tenerife Sur. Servicio técnico para hornos eléctricos y de gas. Reparamos averías complejas en todas las marcas.",
    schema: {
      "@type": "Service",
      "name": "Reparación de Hornos en Tenerife Sur",
      "areaServed": "Tenerife Sur",
      "category": "Reparación Electrodomésticos"
    }
  },
  {
    title: "Microondas",
    icon: "mdi:microwave",
    image: "https://images.unsplash.com/photo-1585659722983-3a675dabf23d?q=80&w=800&auto=format&fit=crop",
    problems: [
      "No calienta",
      "Plato no gira",
      "Ruidos anormales",
      "Chispas internas",
      "Panel no responde"
    ],
    description: " Reparación profesional de microondas en Tenerife Sur. Servicio a domicilio rápido y eficiente. Expertos en todas las marcas y modelos. Garantía en reparaciones.",
    schema: {
      "@type": "Service",
      "name": "Reparación de Microondas en Tenerife Sur",
      "areaServed": "Tenerife Sur",
      "category": "Reparación Electrodomésticos"
    }
  },
  {
    title: "Placas Electrónicas",
    icon: "mdi:chip",
    image: "https://images.unsplash.com/photo-1518770660439-4636190af475?q=80&w=800&auto=format&fit=crop",
    problems: [
      "Fallos en el display",
      "Errores de programación",
      "Problemas de encendido",
      "Cortocircuitos",
      "Componentes dañados"
    ],
    description: "Especialistas en reparación de placas electrónicas de electrodomésticos. Contamos con el equipo y conocimiento necesario para diagnosticar y reparar averías complejas en circuitos y módulos electrónicos.",
    schema: {
      "@type": "Service",
      "name": "Reparación de Placas Electrónicas en Tenerife Sur",
      "areaServed": "Tenerife Sur",
      "category": "Reparación Electrodomésticos"
    }
  }
];

---

<ContentSection title="Nuestros Servicios" id="services">
  <Fragment slot="lead">
    <h2 class="text-3xl font-bold">Servicio Técnico Especializado en Tenerife Sur</h2>
    <p class="mt-4">
      Expertos en <span class="text-primary">reparación de electrodomésticos</span> con más de 15 años de experiencia. 
      Servicio oficial multimarca en toda la zona sur de Tenerife.
    </p>
  </Fragment>
  <div class="grid max-w-6xl grid-cols-1 gap-8 md:grid-cols-2">
    {
      services.map(({ title, icon, image, problems, description, schema }) => (
        <div class="flex flex-col gap-4 border border-default bg-offset p-6 rounded-xl overflow-hidden" itemscope itemtype="https://schema.org/Service">
          <meta itemprop="serviceType" content="Reparación de Electrodomésticos" />
          <meta itemprop="areaServed" content="Tenerife Sur" />
          <meta itemprop="provider" content="S.S.T.TORRES" />
          <div class="relative h-48 w-full overflow-hidden rounded-lg">
            <img
              src={image}
              alt={`Servicio profesional de reparación de ${title} en Tenerife Sur`}
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 hover:scale-105"
              itemprop="image"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent">
              <Icon name={icon} class="absolute bottom-4 right-4 size-12 text-white drop-shadow-lg" />
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="size-12 rounded-full border-2 border-current p-2">
              <Icon name={icon} class="size-full" />
            </div>
            <h3 class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-br from-blue-500 via-blue-400 to-blue-300" itemprop="name">{title}</h3>
          </div>
          <p class="text-offset" itemprop="description">{description}</p>
          <div class="mt-4">
            <h4 class="font-bold mb-2">Problemas más comunes que reparamos:</h4>
            <ul class="grid grid-cols-2 gap-2 text-sm" itemprop="hasOfferCatalog">
              {problems.map((problem) => (
                <li class="flex items-center gap-2" itemprop="itemListElement">
                  <Icon name="mdi:check-circle" class="size-5 text-primary" />
                  <span>{problem}</span>
                </li>
              ))}
            </ul>
          </div>
          <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        </div>
      ))
    }
  </div>
</ContentSection>